# Antigravity token refresh (public Antigravity CLI desktop OAuth client).
# Copy to `.env` in the repo root before building with Antigravity enabled.
# Values are not user secrets — they are embedded in the `agy` binary and documented
# in open-source Antigravity-Manager. Do not commit `.env`.
ANTIGRAVITY_OAUTH_CLIENT_ID=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=
